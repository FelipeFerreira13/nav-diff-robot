<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="wheel_part">

  <xacro:include filename="$(find robot_description)/urdf/diff_terrain/constants.xacro"/>

  <xacro:property name="wheel_mesh" value="file://$(find robot_description)/meshes/terrain_wheel.dae"/>

  <xacro:property name="model_offset_x"     value="-0.20" />              <!-- Fix the mesh model offset -->
  <xacro:property name="model_offset_y"     value="0.15" />               <!-- Fix the mesh model offset -->
  <xacro:property name="file_scale"         value="1.0 1.0 1.0" />        <!-- The STL file is in millimeters -->

  <xacro:macro name="wheel_macro" params="name parent xyz rpy">
    <link name="${name}">
      <visual>
        <geometry>
          <mesh
            filename="${wheel_mesh}"
            scale="${file_scale}"/>            
        </geometry>
        <material name="yellow">
          <color rgba="1 1 0 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.2"/>
        <inertia ixx="0.001" ixy="0" ixz="0"
                 iyy="0.001" iyz="0"
                 izz="0.001"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="continuous">
      <parent link="${parent}"/>
      <child link="${name}"/>
      <origin xyz="${xyz}" rpy="${rpy}"/>
      <axis xyz="0 0 -1"/>
    </joint>
  </xacro:macro>

</robot>