<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro"  name="manipulator_part">

    <xacro:include filename="constants.xacro"/>

    <!-- TOWER -->
    <xacro:macro name="manipulator_part" params="xyz rpy axis">

      <joint name="tower_joint" type="revolute">
          <parent link="base_link"/>
          <child link="tower_link"/>
          <origin xyz="${xyz}" rpy="${rpy}"/>
          <axis xyz="${axis}"/>
          <limit lower="-1.57" upper="1.57" effort="10.0" velocity="1.0"/>
      </joint>

      <xacro:property name="tower_height" value="0.4" />
      <xacro:property name="tower_base" value="0.04" />

      <link name="tower_link">
          <visual>
            <origin xyz="0 0 ${tower_height/2 + chassis_height + wheel_radius}" rpy="0 0 0"/>
            <geometry>
              <box size="${tower_base} ${tower_base} ${tower_height}"/>
            </geometry>
            <material name="blue">
              <color rgba="0 0 1 1"/>
            </material>
          </visual>
          <collision>
            <origin xyz="0 0 ${tower_height/2 + chassis_height + wheel_radius}" rpy="0 0 0"/>
            <geometry>
              <box size="${tower_base} ${tower_base} ${tower_height}"/>
            </geometry>
          </collision>
          <inertial>
            <mass value="0.2"/>
            <inertia ixx="0.001" ixy="0" ixz="0"
                    iyy="0.001" iyz="0"
                    izz="0.001"/>
          </inertial>
      </link>

      <!-- ELEVATOR -->

      <xacro:property name="elev_height" value="0.03" />
      <xacro:property name="elev_base" value="0.04" />

      <joint name="elev_joint" type="prismatic">
          <origin xyz="${tower_base/2 + elev_base/2} 0 0" rpy="0 0 0"/>
          <parent link="tower_link"/>
          <child link="elev_link"/>
          <axis xyz="0 0 1"/>
          <limit lower="${wheel_radius + chassis_height + elev_height/2 + 0.025}" upper="${wheel_radius + chassis_height + tower_height}" velocity="100" effort="100"/> 
      </joint>

      <link name="elev_link">
          <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
              <box size="${elev_base} ${elev_base} ${elev_height}"/>
            </geometry>
            <material name="blue">
              <color rgba="0 0 1 1"/>
            </material>
          </visual>
          <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
              <box size="${elev_base} ${elev_base} ${elev_height}"/>
            </geometry>
          </collision>
          <inertial>
            <mass value="0.2"/>
            <inertia ixx="0.001" ixy="0" ixz="0"
                    iyy="0.001" iyz="0"
                    izz="0.001"/>
          </inertial>
      </link>

      <!-- ARM -->

      <xacro:property name="arm_height" value="0.3" />
      <xacro:property name="arm_base" value="0.04" />

      <joint name="arm_joint" type="prismatic">
          <origin xyz="-${arm_height} -${elev_base/2 + arm_base/2} 0" rpy="0 0 0"/>
          <parent link="elev_link"/>
          <child link="arm_link"/>
          <axis xyz="1 0 0"/>
          <limit lower="0" upper="${arm_height}" velocity="100" effort="100"/> 
      </joint>

      <link name="arm_link">
          <visual>
            <origin xyz="${arm_height/2} 0 0" rpy="0 0 0"/>
            <geometry>
              <box size="${arm_height} ${arm_base} ${arm_base}"/>
            </geometry>
            <material name="blue">
              <color rgba="0 0 1 1"/>
            </material>
          </visual>
          <collision>
            <origin xyz="${arm_height/2} 0 0" rpy="0 0 0"/>
            <geometry>
              <box size="${arm_height} ${arm_base} ${arm_base}"/>
            </geometry>
          </collision>
          <inertial>
            <mass value="0.2"/>
            <inertia ixx="0.001" ixy="0" ixz="0"
                    iyy="0.001" iyz="0"
                    izz="0.001"/>
          </inertial>
      </link>
      
  </xacro:macro>
    
</robot>